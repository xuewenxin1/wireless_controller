  90   2              }
  91   1              if(TuyaOTADisConnectCnt>=6000)
  92   1                      TuyaOTAState = FALSE;
  93   1              //达成回复条件立刻回复模块F
  94   1              if(OTAStartReply)
  95   1              {
  96   2                      OTAStartReply = FALSE;
