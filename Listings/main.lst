  68          void    ModbusChanelControl(void)
  69          {
  70   1              if(TuyaOTAState != OldTuyaOTAState)//OTA状态变化时进行相应初始化F
  71   1              {
  72   2                      OldTuyaOTAState = TuyaOTAState;
  73   2                      if(TuyaOTAState)
  74   2                      {
  75   3                              OTAinit();
  76   3                              Page_Change_Handler(60);//跳转进OTA页面F
  77   3                      }
  78   2                      else
  79   2                      {
  80   3                              Modbus_Read_Initial = TRUE;//重新从主控初始化F
  81   3                              Modbus_Write_Ueser = TRUE;//重写入一次OTA前的运行状态F
  82   3                              OTAReloading = TRUE;//暂停向wifi模块上传版本信息F
  83   3                              OTAReload_Delay = TRUE;//OTA结束后延迟返回主页F
  84   3                      }
  85   2              }
  86   1              if(TuyaOTAState)
  87   1              {
  88   2                      OTA_ModbusPro();
