 240          unsigned short FlashCheckSumCalculate(unsigned short StartAddr, unsigned short Length) // иЊУеЕ•йХњеЇ¶е∞Пд
             -ЇО256*FLASHCALCLEN
 241          {
 242   1              unsigned char i, j, Page, Num;
 243   1              unsigned short FlashCheckSum_Add = 0;
 244   1              unsigned short FlashCheckSum_Buff[FLASHCALCLEN] = {0};
 245   1      
 246   1              Page = Length / FLASHCALCLEN; // еЃМжХізЪДй°µйЭҐжХ∞йЗПF
 247   1              for (i = 0; i < Page; i++)
 248   1              {
 249   2                      read_dgus_vp((u32)(StartAddr + i * FLASHCALCLEN), (u8 *)&FlashCheckSum_Buff, FLASHCALCLEN);
 250   2                      for (j = 0; j < FLASHCALCLEN; j++)
 251   2                      {
 252   3                              FlashCheckSum_Add += FlashCheckSum_Buff[j];
 253   3                      }
 254   2              }
 255   1              Num = Length % FLASHCALCLEN; // еЙ©дљЩйГ®еИЖжХ∞йЗПF
 256   1              read_dgus_vp((u32)(StartAddr + Page * FLASHCALCLEN), (u8 *)&FlashCheckSum_Buff, Num);
 257   1              for (j = 0; j < Num; j++)
 258   1              {
 259   2                      FlashCheckSum_Add += FlashCheckSum_Buff[j];
 260   2              }
 261   1              FlashCheckSum_Add += 1;
 262   1              return FlashCheckSum_Add;
 263   1      }
