 227          unsigned short FlashCheckSumCalculate(unsigned short StartAddr, unsigned short Length) // è¾“ه…¥é•؟ه؛¦ه°ڈن
             -؛ژ256*FLASHCALCLEN
 228          {
 229   1              unsigned char i, j, Page, Num;
