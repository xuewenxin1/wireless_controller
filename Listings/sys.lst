             -ҸеҸҜиҠӮзңҒз©әй—ҙF
 236          unsigned short FlashCheckSumCalculate(unsigned short StartAddr, unsigned short Length) // иҫ“е…Ҙй•ҝеәҰе°Ҹд
             -әҺ256*FLASHCALCLEN
 237          {
 238   1              unsigned char i, j, Page, Num;
C51 COMPILER V9.59.0.0   SYS                                                               07/08/2026 17:17:07 PAGE 5   

 239   1              unsigned short FlashCheckSum_Add = 0;
 240   1              unsigned short FlashCheckSum_Buff[FLASHCALCLEN] = {0};
 241   1      
 242   1              Page = Length / FLASHCALCLEN; // е®Ңж•ҙзҡ„йЎөйқўж•°йҮҸF
 243   1              for (i = 0; i < Page; i++)
 244   1              {
 245   2                      read_dgus_vp((u32)(StartAddr + i * FLASHCALCLEN), (u8 *)&FlashCheckSum_Buff, FLASHCALCLEN);
 246   2                      for (j = 0; j < FLASHCALCLEN; j++)
 247   2                      {
 248   3                              FlashCheckSum_Add += FlashCheckSum_Buff[j];
 249   3                      }
 250   2              }
 251   1              Num = Length % FLASHCALCLEN; // еү©дҪҷйғЁеҲҶж•°йҮҸF
 252   1              read_dgus_vp((u32)(StartAddr + Page * FLASHCALCLEN), (u8 *)&FlashCheckSum_Buff, Num);
 253   1              for (j = 0; j < Num; j++)
 254   1              {
 255   2                      FlashCheckSum_Add += FlashCheckSum_Buff[j];
 256   2              }
 257   1              FlashCheckSum_Add += 1;
 258   1              return FlashCheckSum_Add;
 259   1      }
