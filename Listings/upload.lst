  23          static u8 Upload_UlToStr(u32 v, char *buf)
  24          {
  25   1              char rev[10];
  26   1              u8 n = 0;
  27   1              u8 i;
  28   1      
  29   1              if(v == 0)
  30   1              {
  31   2                      buf[0] = '0';
  32   2                      buf[1] = '\0';
  33   2                      return 1;
  34   2              }
  35   1              while(v && n < sizeof(rev))
  36   1              {
  37   2                      rev[n++] = (char)('0' + (v % 10));
  38   2                      v /= 10;
  39   2              }
  40   1              for(i = 0; i < n; i++)
  41   1                      buf[i] = rev[n - 1 - i];
  42   1              buf[n] = '\0';
  43   1              return n;
  44   1      }
