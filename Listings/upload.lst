  27          static u8 Upload_UlToStr(u32 v, char *buf)
  28          {
  29   1              char rev[10];
  30   1              u8 n = 0;
  31   1              u8 i;
  32   1      
  33   1              if(v == 0)
  34   1              {
  35   2                      buf[0] = '0';
  36   2                      buf[1] = '\0';
  37   2                      return 1;
  38   2              }
  39   1              while(v && n < sizeof(rev))
  40   1              {
  41   2                      rev[n++] = (char)('0' + (v % 10));
  42   2                      v /= 10;
  43   2              }
  44   1              for(i = 0; i < n; i++)
  45   1                      buf[i] = rev[n - 1 - i];
  46   1              buf[n] = '\0';
  47   1              return n;
  48   1      }
