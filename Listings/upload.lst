  14          static u8 Upload_UlToStr(u32 v, char *buf)
  15          {
  16   1              char rev[10];
  17   1              u8 n = 0;
  18   1              u8 i;
  19   1      
  20   1              if(v == 0)
  21   1              {
  22   2                      buf[0] = '0';
  23   2                      buf[1] = '\0';
  24   2                      return 1;
  25   2              }
  26   1              while(v && n < sizeof(rev))
  27   1              {
  28   2                      rev[n++] = (char)('0' + (v % 10));
  29   2                      v /= 10;
  30   2              }
  31   1              for(i = 0; i < n; i++)
  32   1                      buf[i] = rev[n - 1 - i];
  33   1              buf[n] = '\0';
  34   1              return n;
  35   1      }
  36          
