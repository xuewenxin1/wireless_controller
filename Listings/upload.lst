  65   1              u8 mask = 0;
  66   1      
  67   1              for(i = 0; i < 6; i++)
  68   1              {
  69   2                      read_dgus_vp((u32)(0x4860 + i), (u8 *)&sel, 1);
  70   2                      if(sel)
  71   2                      {
  72   3                              count++;
  73   3                              single_room = (u8)(i + 1);
  74   3                              mask |= (u8)(1 << i);
  75   3                      }
  76   2              }
  77   1              if(count == 1)
  78   1                      return single_room;
  79   1              return mask;
  80   1      }
