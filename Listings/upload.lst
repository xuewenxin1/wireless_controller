 666   1              static u8 s_cmd8_idx = 0;
 667   1      
 668   1              s_invalidate_scalar = 1;
 669   1              switch(s_cmd8_idx)
 670   1              {
 671   2              case 0: upload_dp_switch(); break;
 672   2              case 1: upload_dp_mode(); break;
 673   2              case 2: upload_dp_temp_set(); break;
 674   2              case 3: upload_dp_temp_unit(); break;
C51 COMPILER V9.59.0.0   UPLOAD                                                            06/30/2026 14:47:52 PAGE 12  

 675   2              case 4: upload_dp_child_lock(); break;
 676   2              case 5: upload_dp_defrost(); break;
 677   2              case 6: upload_dp_relay_status(); break;
 678   2              default: upload_dp_work_state(); break;
 679   2              }
 680   1              s_invalidate_scalar = 0;
 681   1              s_cmd8_idx++;
 682   1              if(s_cmd8_idx > 7)
 683   1                      s_cmd8_idx = 0;
 684   1      }
