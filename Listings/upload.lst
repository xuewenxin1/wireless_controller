  26          static u8 Upload_UlToStr(u32 v, char *buf)
  27          {
  28   1              char rev[10];
  29   1              u8 n = 0;
  30   1              u8 i;
  31   1      
  32   1              if(v == 0)
  33   1              {
  34   2                      buf[0] = '0';
  35   2                      buf[1] = '\0';
  36   2                      return 1;
  37   2              }
  38   1              while(v && n < sizeof(rev))
  39   1              {
  40   2                      rev[n++] = (char)('0' + (v % 10));
  41   2                      v /= 10;
  42   2              }
  43   1              for(i = 0; i < n; i++)
  44   1                      buf[i] = rev[n - 1 - i];
  45   1              buf[n] = '\0';
  46   1              return n;
  47   1      }
