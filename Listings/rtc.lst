 487          u32 RTC_GetUnixLocal(void)
 488          {
 489   1              u32 days = 0;
 490   1              u16 year;
 491   1              u8 month;
 492   1              u16 full_year;
 493   1      
 494   1              full_year = (u16)s_rtc_year + 2000;
 495   1              for(year = 1970; year < full_year; year++)
 496   1                      days += rtc_is_leap(year) ? 366UL : 365UL;
 497   1              for(month = 1; month < s_rtc_month; month++)
 498   1                      days += rtc_days_in_month(full_year, month);
 499   1              if(s_rtc_day > 0)
 500   1                      days += (u32)(s_rtc_day - 1);
 501   1              return days * 86400UL + (u32)s_rtc_hour * 3600UL + (u32)s_rtc_min * 60UL + (u32)s_rtc_sec;
 502   1      }
