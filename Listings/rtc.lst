 249          unsigned char rtc_get_week(unsigned char year, unsigned char month, unsigned char day)
 250          {
 251   1              unsigned int tmp, mon, y;
 252   1              unsigned char week;
 253   1              if ((month == 1) || (month == 2))
 254   1              {
 255   2                      mon = month + 12;
 256   2                      y = year - 1;
 257   2              }
 258   1              else
 259   1              {
 260   2                      mon = month;
 261   2                      y = year;
 262   2              }
 263   1              tmp = y + (y / 4) + (((mon + 1) * 26) / 10) + day - 36;
 264   1              week = tmp % 7;
 265   1              return week;
 266   1      }
