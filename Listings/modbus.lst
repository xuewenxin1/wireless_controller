 152          u16 CalculateModbusCrc(u8 *pBuf, u16 nLen)
 153          {
 154   1              u16 i;
 155   1              u8      j;
 156   1              u16 nData;
 157   1              u16 nFlag;
 158   1              
 159   1              nData = 0xFFFF;
 160   1              for (i=0; i<nLen; i++)
 161   1              {
 162   2                      nData = nData ^ pBuf[i];
 163   2                      for (j=0; j<8; j++)
 164   2                      {
 165   3                              nFlag = nData & 0x01;
 166   3                              nData = nData >> 1;
 167   3                              nData = nData & 0x7fff;
 168   3                              
 169   3                              if (nFlag != 0)
 170   3                              {
 171   4                                      nData = nData ^ 0xa001;
 172   4                              }
 173   3                      }
 174   2              }
C51 COMPILER V9.59.0.0   MODBUS                                                            07/08/2026 17:17:07 PAGE 4   

 175   1              
 176   1              return nData;
 177   1      }
