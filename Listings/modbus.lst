 324          static u16 Modbus_EncodeIndoorRunMode(u16 power, u16 dgus_mode)
 325          {
 326   1              u16 modbus_mode;
 327   1              if(power == 0)
 328   1                      return 0;
 329   1              switch(dgus_mode)
 330   1              {
 331   2                      case 0: modbus_mode = 2; break; /* 制冷 */
 332   2                      case 1: modbus_mode = 6; break; /* 除湿 */
 333   2                      case 2: modbus_mode = 1; break; /* 送风 */
 334   2                      case 3: modbus_mode = 3; break; /* 制热 */
 335   2                      case 4: modbus_mode = 7; break; /* 自动 */
 336   2                      default: modbus_mode = 7; break;
 337   2              }
 338   1              return (u16)(0x0080 | modbus_mode);
 339   1      }
 340          
 341          static u16 Modbus_EncodeIndoorFan(u16 dgus_fan)
 342          {
 343   1              switch(dgus_fan)
 344   1              {
 345   2                      case 0: return 8; /* 自动风 */
 346   2                      case 1: return 2; /* 低风 */
 347   2                      case 2: return 4; /* 中风 */
 348   2                      case 3: return 6; /* 高风 */
 349   2                      case 4: return 7; /* 超高风 */
 350   2                      default: return 8;
 351   2              }
 352   1      }
