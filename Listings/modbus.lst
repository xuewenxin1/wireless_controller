 229   1              {
 230   2                      case 0: return 8; /* 自动风 */
 231   2                      case 1: return 2; /* 低风 */
 232   2                      case 2: return 4; /* 中风 */
 233   2                      case 3: return 6; /* 高风 */
 234   2                      case 4: return 7; /* 超高风 */
 235   2                      default: return 8;
 236   2              }
