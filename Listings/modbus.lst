  86          u16 CalculateModbusCrc(u8 *pBuf, u16 nLen)
  87          {
  88   1              u16 i;
  89   1              u8      j;
  90   1              u16 nData;
  91   1              u16 nFlag;
  92   1              
  93   1              nData = 0xFFFF;
  94   1              for (i=0; i<nLen; i++)
  95   1              {
  96   2                      nData = nData ^ pBuf[i];
  97   2                      for (j=0; j<8; j++)
  98   2                      {
  99   3                              nFlag = nData & 0x01;
 100   3                              nData = nData >> 1;
 101   3                              nData = nData & 0x7fff;
 102   3                              
 103   3                              if (nFlag != 0)
 104   3                              {
 105   4                                      nData = nData ^ 0xa001;
 106   4                              }
 107   3                      }
 108   2              }
 109   1              
 110   1              return nData;
 111   1      }
