 354          static u16 Modbus_DecodeIndoorModeBits(u16 reg)
 355          {
 356   1              switch(reg & 0x0007)
 357   1              {
 358   2                      case 2: return 0; /* 制冷 */
 359   2                      case 6: return 1; /* 除湿 */
 360   2                      case 1: return 2; /* 送风 */
C51 COMPILER V9.59.0.0   MODBUS                                                            07/08/2026 17:12:48 PAGE 7   

 361   2                      case 3: return 3; /* 制热 */
 362   2                      case 7: return 4; /* 自动 */
 363   2                      default: return 0;
 364   2              }
 365   1      }
 366          
 367          static u16 Modbus_DecodeIndoorFan(u16 reg)
 368          {
 369   1              if(reg == 8)
 370   1                      return 0;
 371   1              if(reg == 0)
 372   1                      return 0;
 373   1              if(reg <= 2)
 374   1                      return 1;
 375   1              if(reg <= 4)
 376   1                      return 2;
 377   1              if(reg <= 6)
 378   1                      return 3;
 379   1              return 4;
 380   1      }
