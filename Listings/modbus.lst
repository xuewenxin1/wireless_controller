 219          static u16 Modbus_DecodeIndoorFan(u16 reg)
 220          {
 221   1              if(reg == 8)
 222   1                      return 0;
 223   1              if(reg == 0)
 224   1                      return 0;
 225   1              if(reg <= 2)
