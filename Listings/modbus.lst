 176          static u16 Modbus_EncodeIndoorRunMode(u16 power, u16 dgus_mode)
 177          {
 178   1              u16 modbus_mode;
 179   1              if(power == 0)
 180   1                      return 0;
 181   1              switch(dgus_mode)
 182   1              {
 183   2                      case 0: modbus_mode = 2; break; /* 制冷 */
 184   2                      case 1: modbus_mode = 6; break; /* 除湿 */
 185   2                      case 2: modbus_mode = 1; break; /* 送风 */
 186   2                      case 3: modbus_mode = 3; break; /* 制热 */
 187   2                      case 4: modbus_mode = 7; break; /* 自动 */
 188   2                      default: modbus_mode = 7; break;
 189   2              }
 190   1              return (u16)(0x0080 | modbus_mode);
 191   1      }
