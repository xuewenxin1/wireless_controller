 266          
 267          u16 CalculateModbusCrc(u8 *pBuf, u16 nLen)
 268          {
 269   1              u16 i;
 270   1              u8      j;
 271   1              u16 nData;
 272   1              u16 nFlag;
 273   1              
 274   1              nData = 0xFFFF;
 275   1              for (i=0; i<nLen; i++)
 276   1              {
 277   2                      nData = nData ^ pBuf[i];
 278   2                      for (j=0; j<8; j++)
 279   2                      {
 280   3                              nFlag = nData & 0x01;
 281   3                              nData = nData >> 1;
 282   3                              nData = nData & 0x7fff;
 283   3                              
 284   3                              if (nFlag != 0)
 285   3                              {
 286   4                                      nData = nData ^ 0xa001;
 287   4                              }
 288   3                      }
 289   2              }
 290   1              
 291   1              return nData;
 292   1      }
