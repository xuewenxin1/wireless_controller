 209          static u16 Modbus_EncodeIndoorRunMode(u16 power, u16 dgus_mode)
 210          {
 211   1              u16 modbus_mode;
 212   1              if(power == 0)
 213   1                      return 0;
 214   1              switch(dgus_mode)
 215   1              {
 216   2                      case 0: modbus_mode = 2; break; /* 制冷 */
 217   2                      case 1: modbus_mode = 6; break; /* 除湿 */
 218   2                      case 2: modbus_mode = 1; break; /* 送风 */
 219   2                      case 3: modbus_mode = 3; break; /* 制热 */
 220   2                      case 4: modbus_mode = 7; break; /* 自动 */
 221   2                      default: modbus_mode = 7; break;
 222   2              }
 223   1              return (u16)(0x0080 | modbus_mode);
 224   1      }
