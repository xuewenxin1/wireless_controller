 399          static u8 Modbus_IsFaultActive(u16 err_code, u16 *err_words)
 400          {
 401   1              u8 wi, bi;
 402   1      
 403   1              if(err_code == 0)
 404   1                      return 0;
 405   1              wi = (u8)((err_code - 1) / 16);
 406   1              bi = (u8)((err_code - 1) % 16);
 407   1              if(wi >= 4)
 408   1                      return 0;
 409   1              return (err_words[wi] >> bi) & 0x01;
 410   1      }
