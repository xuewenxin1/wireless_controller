 252          static u16 Modbus_DecodeIndoorFan(u16 reg)
 253          {
 254   1              if(reg == 8)
 255   1                      return 0;
 256   1              if(reg == 0)
 257   1                      return 0;
 258   1              if(reg <= 2)
