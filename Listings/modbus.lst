 119          u16 CalculateModbusCrc(u8 *pBuf, u16 nLen)
 120          {
 121   1              u16 i;
 122   1              u8      j;
 123   1              u16 nData;
 124   1              u16 nFlag;
 125   1              
 126   1              nData = 0xFFFF;
 127   1              for (i=0; i<nLen; i++)
 128   1              {
 129   2                      nData = nData ^ pBuf[i];
 130   2                      for (j=0; j<8; j++)
 131   2                      {
 132   3                              nFlag = nData & 0x01;
 133   3                              nData = nData >> 1;
 134   3                              nData = nData & 0x7fff;
 135   3                              
 136   3                              if (nFlag != 0)
 137   3                              {
 138   4                                      nData = nData ^ 0xa001;
 139   4                              }
 140   3                      }
 141   2              }
 142   1              
 143   1              return nData;
 144   1      }
