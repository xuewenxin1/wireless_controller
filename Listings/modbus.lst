 439          static u16 Modbus_EncodeIndoorRunMode(u16 power, u16 dgus_mode)
 440          {
 441   1              u16 modbus_mode;
 442   1              if(power == 0)
 443   1                      return 0;
 444   1              switch(dgus_mode)
 445   1              {
 446   2                      case 0: modbus_mode = 2; break; /* 制冷 */
 447   2                      case 1: modbus_mode = 6; break; /* 除湿 */
 448   2                      case 2: modbus_mode = 1; break; /* 送风 */
 449   2                      case 3: modbus_mode = 3; break; /* 制热 */
 450   2                      case 4: modbus_mode = 7; break; /* 自动 */
 451   2                      default: modbus_mode = 7; break;
 452   2              }
 453   1              return (u16)(0x0080 | modbus_mode);
 454   1      }
