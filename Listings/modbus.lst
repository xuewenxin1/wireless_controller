 193          static u16 Modbus_EncodeIndoorFan(u16 dgus_fan)
 194          {
 195   1              switch(dgus_fan)
 196   1              {
 197   2                      case 0: return 8; /* 自动风 */
 198   2                      case 1: return 2; /* 低风 */
 199   2                      case 2: return 4; /* 中风 */
 200   2                      case 3: return 6; /* 高风 */
 201   2                      case 4: return 7; /* 超高风 */
 202   2                      default: return 8;
 203   2              }
 204   1      }
