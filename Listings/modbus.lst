 381          
 382          u16 CalculateModbusCrc(u8 *pBuf, u16 nLen)
 383          {
 384   1              u16 i;
 385   1              u8      j;
 386   1              u16 nData;
 387   1              u16 nFlag;
 388   1              
 389   1              nData = 0xFFFF;
 390   1              for (i=0; i<nLen; i++)
 391   1              {
 392   2                      nData = nData ^ pBuf[i];
 393   2                      for (j=0; j<8; j++)
 394   2                      {
 395   3                              nFlag = nData & 0x01;
 396   3                              nData = nData >> 1;
 397   3                              nData = nData & 0x7fff;
 398   3                              
 399   3                              if (nFlag != 0)
 400   3                              {
 401   4                                      nData = nData ^ 0xa001;
 402   4                              }
 403   3                      }
 404   2              }
 405   1              
 406   1              return nData;
 407   1      }
