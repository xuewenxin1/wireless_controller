                     514     
0001                 515     ?B_SWITCHBANK_A:
0001 900000   F      516                     MOV     DPTR,#switch_tab
0004 93              517                     MOVC    A,@A+DPTR
0005                 518     ?B_RESTORE_BANK:                       ; entry for RTX-51/XBANKING bank restore
0005 900000   F      519                     MOV     DPTR,#?BANK?SWITCH
0008 73              520                     JMP     @A+DPTR
                     521     
                     522     S_ENTRY         MACRO   N
                     523                     DB      LOW ?B_SWITCH&N
                     524                     ENDM
                     525     
0009                 526     switch_tab:
  0000               527     CNT             SET     0
                     528     
                     529                     REPT    ?B_NBANKS
                     530                     S_ENTRY %CNT
                     531     CNT             SET     CNT+1
                     532                     ENDM
                     533+1                   S_ENTRY %CNT
                     536+1                   S_ENTRY %CNT
                     539+1                   S_ENTRY %CNT
                     542+1                   S_ENTRY %CNT
                     545+1                   S_ENTRY %CNT
                     548+1                   S_ENTRY %CNT
                     551+1                   S_ENTRY %CNT
                     554+1                   S_ENTRY %CNT
                     557     
                     558     ENDIF  ; close block IF ?B_MODE = 4 *******************************************
