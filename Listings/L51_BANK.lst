                       9     ;------------------------------------------------------------------------------
                      10     ;************************ Configuration Section *******************************
                      11     ;<h> Bank Configuration
                      12     ;
                      13     ;     <i> Program Code in expanded memory is supported via the code banking mechanism
                      14     ;     <i> known from the classic 8051 architecture.  You need to specify the number
                      15     ;     <i> of code banks that are required for your application.
                      16     ;
                      17     ; <o> ?B_NBANKS: Number of Banks
                      18     ;                    <2=> 2
                      19     ;                    <4=> 4
                      20     ;                    <8=> 8
                      21     ;                    <16=> 16
                      22     ;                    32=> 32
                      23     ;                    64=> 64
                      24     ;                         <i> For BL51 the maximum value for ?B_NBANKS is 32
                      25     ;                         <i> For LX51 the maximum value for ?B_NBANKS is 64
  0008                26     ?B_NBANKS       EQU  8    ; Define maximum Number of Banks
                      27     ;                         ; following values are allowed: 2, 4, 8, 16, 32, 64
                      28     ;                         ; for BL51 the maximum value for ?B_NBANKS is 32
                      29     ;                         ; for LX51 the maximum value for ?B_NBANKS is 64
                      30     ;
                      31     ; <o> ?B_MODE: Bank Switching via
                      32     ;                    <0=> 8051 Port
                      33     ;                    <1=> XDATA Port
                      34     ;                    <4=> User-provided bank switch code
  0004                35     ?B_MODE         EQU  4    ; 0 for Bank-Switching via 8051 Port
                      36     ;                         ; 1 for Bank-Switching via XDATA Port
                      37     ;                         ; 4 for user-provided bank switch code
                      38     ;
                      39     ; <q> ?B_RTX: The application uses RTX-51 Real-time OS
  0000                40     ?B_RTX          EQU  0    ; 0 for applications without real-time OS
                      41     ;                         ; 1 for applications using the RTX-51 real-time OS
                      42     ;
                      43     ; <o> ?B_RST_BANK: Active code bank number after a Reset <0x0-0xFF>
                      44     ;     <i> Notes:
                      45     ;     <i> 1. This specifies the active code bank number after CPU reset.
                      46     ;     <i>    It is used to reduce the entries in the INTERBANK CALL TABLE.
                      47     ;     <i> 2. The value 0xFF disables LX51 linker/locater optimization.
                      48     ;     <i> 3. Interbank Call Table optimization is only possible with LX51.
  0000                49     ?B_RST_BANK     EQU  0x00 ; specifies the active code bank number after CPU
                      50     ;                         ; Reset.  Used to reduce the entries in the
                      51     ;                         ; INTERBANK CALL TABLE.  The value 0xFF disables
                      52     ;                         ; this LX51 linker/locater optimization.
                      53     ; Note:  Interbank Call Table optimization is only possible with LX51.
                      54     ;
                      55     ;</h>
                      56     ;-----------------------------------------------------------------------------
                      57     ;
A51 MACRO ASSEMBLER  L51_BANK                                                             07/08/2026 17:12:48 PAGE     2

                      58     IF  ?B_MODE = 4;
                      59     ;-----------------------------------------------------------------------------
                      60     ; if ?BANK?MODE is 4 define the following switch macros
                      61     ; For bank switching via user-provided bank switch code you must define for
                      62     ; each memory bank your own macro which contains the bank switch code.  The
                      63     ; following example shows how to use the I/O lines P1.4 and P1.7 for bank
                      64     ; switching.  Since you can select only 4 banks with two address lines, only
                      65     ; four macros are defined.  The number of macros must conform with the number
                      66     ; ?B_NBANKS number, i.e. for an application with 16 memory banks you must
                      67     ; define 16 macros.
                      68     ;
                      69     ; IMPORTANT NOTES:
                      70     ; 1. The bank switch logic must be initialized before using it.  Therefore
                      71     ;    add the following lines of code at the end of the STARTUP.A51 file:
                      72     ;
                      73     ;      EXTRN CODE (?B_SWITCH0)
                      74     ;               CALL    ?B_SWITCH0    ; init bank mechanism to code bank 0
                      75     ;               LJMP    ?C_START      ; line already exits at the end of file
                      76     ;
                      77     ;
                      78     ; 2. If the bank switch macros and the additional control code generate more
                      79     ;    than 256 bytes, you need to set the LONG_MACRO flag below.  The error
                      80     ;    message "BANK SWITCH CODE BIGGER THAN 256 BYTES, SET LONG_MACRO TO 1"
                      81     ;    is generated in case that this is required.
                      82     ;
                      83     ; 3. The only registers that can be modified in this routines without prior
                      84     ;    saving are:  DPTR and ACC.
                      85     ;
                      86     ;
                      87     ; <h> Bank Switching via User Provided Code
                      88     ;     <i> This is only used if ?B_MODE is 4
                      89     ; <o> LONG_MACRO: Macro size and number of banks
                      90     ;               <0=> Macros use less than 257 bytes and 8 banks or less
                      91     ;               <1=> Macros use more than 256 bytes and more than 8 banks
  0000                92     LONG_MACRO      EQU  0    ; 0 default, for normal macros and up to 8 banks
                      93     ;                         ; 1 big macro code or many banks
                      94     ;
                      95     ;-----------------------------------------------------------------------------
                      96     ;
                      97     ; Standard SFR Symbols required in L51_BANK.A51
  0090                98     P1                              DATA    90H
  00B0                99     P3                              DATA    0B0H
  00E0               100     ACC                             DATA    0E0H
  00F0               101     B                               DATA    0F0H
  0081               102     SP                              DATA    81H
  0082               103     DPL                             DATA    82H
  0083               104     DPH                             DATA    83H
  0093               105     DPC                             DATA    93H
  00F8               106     RAMMODE                 DATA    0F8H
  00D0               107     PSW                             DATA    0D0H
  0095               108     D_PAGESEL               DATA    95H
  00FA               109     DATA3                   DATA    0FAH
  00FB               110     DATA2                   DATA    0FBH
  00FC               111     DATA1                   DATA    0FCH
  00FD               112     DATA0                   DATA    0FDH
  00F1               113     ADR_H                   DATA    0F1H
  00F2               114     ADR_M                   DATA    0F2H
  00F3               115     ADR_L                   DATA    0F3H
  00F4               116     ADR_INC                 DATA    0F4H
  00FC               117     APP_ACK                 BIT     0FCH
  00FD               118     APP_RW                  BIT     0FDH
  00FE               119     APP_EN                  BIT     0FEH
  00AF               120     EA      BIT     0AFH
                     121     ;
                     122     ;
                     123     ;
A51 MACRO ASSEMBLER  L51_BANK                                                             07/08/2026 17:12:48 PAGE     3

                     124     ;-----------------------------------------------------------------------------
                     125     ;
                     126     SWITCH_BANK_SPACE       SEGMENT CODE
----                 127                                     RSEG    SWITCH_BANK_SPACE
                     128     ;-----------------------------------------------------------------------------
                     129     ;读取bankN代码到RAM
0000                 130     BANKS_SWITCH:
                     131                                     ;CLR            P1.1
0000 F500     F      132                                     MOV     BANK_SWITCH_A,A
0002 858300   F      133                                     MOV     BANK_SWITCH_DPH,DPH
0005 858200   F      134                                     MOV     BANK_SWITCH_DPL,DPL
                     135                     ;计算VP双字地址
0008 75F100          136                     MOV             ADR_H,#00H
000B E500     F      137                     MOV     A,BANK_SWITCH_PSW;数值为0-7,
000D 85D000   F      138                                     MOV     BANK_SWITCH_PSW,PSW
0010 C4              139                                     SWAP    A
0011 D2E7            140                                     SETB    ACC.7
0013 F5F2            141                     MOV             ADR_M,A;访问8000-F000之间的双字空间
0015 75F300          142                     MOV             ADR_L,#00H
0018 75F401          143                     MOV             ADR_INC,#01H;VP自增模式
001B 75F8AF          144                     MOV             RAMMODE,#0AFH;读数据
001E 30FCFD          145                     JNB             APP_ACK,$ ;等待APP_ACK标志位为1
0021 900100          146                                     MOV             DPTR,#0100H     
0024 D2FE            147     READC:          SETB    APP_EN
0026 20FEFD          148                     JB              APP_EN,$
0029 E5FA            149                     MOV             A,DATA3
002B F0              150                     MOVX    @DPTR,A
002C A3              151                     INC     DPTR
002D E5FB            152                     MOV             A,DATA2
002F F0              153                     MOVX    @DPTR,A
0030 A3              154                     INC     DPTR
0031 E5FC            155                     MOV             A,DATA1
0033 F0              156                     MOVX    @DPTR,A
0034 A3              157                     INC     DPTR
0035 E5FD            158                     MOV             A,DATA0
0037 F0              159                     MOVX    @DPTR,A
0038 A3              160                     INC     DPTR
0039 E583            161                                     MOV     A,DPH
003B B441E6          162                     CJNE    A,#41H,READC
003E 75F800          163                     MOV     RAMMODE,#00H
                     164                                     
0041 E500     F      165                                     MOV     A,BANK_SWITCH_A
0043 850083   F      166                                     MOV     DPH,BANK_SWITCH_DPH
0046 850082   F      167                                     MOV     DPL,BANK_SWITCH_DPL
0049 8500D0   F      168                                     MOV     PSW,BANK_SWITCH_PSW
                     169                                     ;SETB           P1.1
004C 22              170                     RET
                     171     ; </h>
                     172     ;-----------------------------------------------------------------------------
                     173     ;用于上电第一次加载bank0
                     174     PUBLIC LOAD_BANK0
004D                 175             LOAD_BANK0:
004D 750000   F      176                                     MOV             ?B_CURRENTBANK,#LOW ?B_SWITCH0
0050 22              177                                     RET
                     178     
                     179     
                     180     ENDIF;
                     181     ;
                     182     ;
                     183     ;******************************************************************************
                     184     ;                                                                             *
                     185     ; THEORY OF OPERATION                                                         *
                     186     ; -------------------                                                         *
                     187     ; The section below describes the code generated by BL51 or LX51 and the      *
                     188     ; operation of the L51_BANK.A51 module.  BL51/LX51 generates for each         *
                     189     ; function that is located in a code memory bank and called from the common   *
A51 MACRO ASSEMBLER  L51_BANK                                                             07/08/2026 17:12:48 PAGE     4

                     190     ; area or a different code bank and entry into the INTRABANK CALL TABLE.  The *
                     191     ; INTRABANK CALL TABLE is located in the SEGMENT ?BANK?SELECT and listed in   *
                     192     ; the Linker MAP file. The entries in that TABLE have the following format:   *
                     193     ;                                                                             *
                     194     ;   ?FCT?1:  MOV  DPTR,#FCT     ; Load Address of target FCT                  *
                     195     ;            JMP  ?B_BANKn      ; Switch to Bank and Jump to Target Code      *
                     196     ;                                                                             *
                     197     ; Instead of directly calling the function FCT, the Linker changes the entry  *
                     198     ; to ?FCT?1.  This entry selects the bank where the function FCT is located   *
                     199     ; and calls that function via the routines defined in this L51_BANK.A51 file. *
                     200     ; The L51_BANK.A51 file contains two sets of functions for each bank:         *
                     201     ;                                                                             *
                     202     ; ?B_BANKn    is a routine which saves the entry of the ?B_SWITCHn function   *
                     203     ;             for the current active bank on the STACK and switches to the    *
                     204     ;             bank 'n'.  Then it jumps to the address specified by the DPTR   *
                     205     ;             register.  It is allowed to modify the following registers in   *
                     206     ;             the ?B_BANKn routine:  A, B, R0, DPTR, PSW                      *
                     207     ;                                                                             *
                     208     ; ?B_SWITCHn  is a function which selects the bank 'n'.  This function is     *
                     209     ;             used at the end of a user function to return to the calling     *
                     210     ;             code bank.  Only the following registers may be altered in the  *
                     211     ;             ?B_SWITCHn function:  R0, DPTR                                  *
                     212     ;                                                                             *
                     213     ; The current active bank is stored in ?B_CURRENTBANK.  RTX-51 uses this      *
                     214     ; variable to restore the code bank after a task switch.  To get correct      *
                     215     ; results, ?B_CURRENTBANK must be set to the code bank before the hardware    *
                     216     ; switch is done, or the code banking sequences must be interrupt protected.  *
                     217     ;******************************************************************************
                     218     
                     219                     NAME    ?BANK?SWITCHING
                     220     
                     221                     PUBLIC  ?B_NBANKS, ?B_MODE, ?B_CURRENTBANK, ?B_MASK
                     222                     PUBLIC  ?B_FACTOR, ?B_RST_BANK
                             ENDIF
                     226     
                     227     ; generate Mask and Bank Number Information
                             ELSEIF  ?B_NBANKS <= 8
  0007               233       MASK          EQU     00000111B
                             ENDIF
                     241     
                     242     
                     243     IF  ?B_MODE = 4 ;**************************************************************
                     244     
  0000               245     ?B_FACTOR       EQU     0               ; Dummy Declarations
  0000               246     ?B_FIRSTBIT     EQU     0
  0007               247     ?B_MASK         EQU     MASK
                     248     
                     249     ?BANK?SELECT    SEGMENT CODE
                     250     ?BANK?DATA      SEGMENT DATA
----                 251                     RSEG    ?BANK?DATA
0000                 252     ?B_CURRENTBANK:  DS     1
0001                 253     BANK_SWITCH_DPH: DS     1
0002                 254     BANK_SWITCH_DPL: DS     1
0003                 255     BANK_SWITCH_A:   DS     1
0004                 256     BANK_SWITCH_PSW: DS     1
                     257     
                     258     BANK            MACRO   N
                     259                     PUBLIC  ?B_BANK&N
                     260     ?B_BANK&N:
                     261                     PUSH    ?B_CURRENTBANK
                     262                     MOV             A,#HIGH ?BANK?SWITCH
                     263                     PUSH    ACC
                     264                     PUSH    DPL
                     265                     PUSH    DPH
                     266                     ENDM
                     267     
A51 MACRO ASSEMBLER  L51_BANK                                                             07/08/2026 17:12:48 PAGE     5

                     268     SWITCH          MACRO   N
                     269                     PUBLIC  ?B_SWITCH&N
                     270       IF (LONG_MACRO = 1)
                     271         ?B_SWITCHJ&N:
                     272       ELSE
                     273         ?B_SWITCH&N:
                     274       ENDIF
                     275                     ;CLR EA
                     276                     MOV             ?B_CURRENTBANK,#LOW ?B_SWITCH&N
                     277                     MOV             BANK_SWITCH_PSW,#N
                     278                     CALL    BANKS_SWITCH
                     279                     ;SETB EA
                     280                     RET
                     281                     ENDM
                     282     
                               ENDIF
                     289     
                     290     ?BANK?SWITCH    SEGMENT CODE PAGE
                     291     
----                 292                     RSEG    ?BANK?SWITCH
  0000               293     B_SWITCH_START  EQU     $
                     294     
                               ENDIF
                     304     
                     305     
                     306     ; Generate ?B_SWITCHn functions
  0000               307     CNT             SET     0
                     308     
                     309                     REPT    ?B_NBANKS
                     310                     BANK    %CNT
                     311                     SWITCH  %CNT
                     312     CNT             SET     CNT+1
                     313                     ENDM
                     314+1                   BANK    %CNT
                     322+1                   SWITCH  %CNT
                     336+1                   BANK    %CNT
                     344+1                   SWITCH  %CNT
                     358+1                   BANK    %CNT
                     366+1                   SWITCH  %CNT
                     380+1                   BANK    %CNT
                     388+1                   SWITCH  %CNT
                     402+1                   BANK    %CNT
                     410+1                   SWITCH  %CNT
                     424+1                   BANK    %CNT
                     432+1                   SWITCH  %CNT
                     446+1                   BANK    %CNT
                     454+1                   SWITCH  %CNT
                     468+1                   BANK    %CNT
                     476+1                   SWITCH  %CNT
                     490     
  00A0               491     B_SWITCH_SIZE   EQU     $-B_SWITCH_START
                     492     
                               ENDIF
                     496     
                     497     ENDIF  ; close block IF ?B_MODE = 4 *******************************************
