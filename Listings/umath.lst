 245          u16 Calculate_CRC16(unsigned char *updata, unsigned char len ,unsigned char mode)
 246          {
 247   1          unsigned int Reg_CRC=0xffff;
 248   1          unsigned char i,j;
 249   1          for (i=0;i<len;i++)
 250   1          {
 251   2              Reg_CRC^=*updata++;
 252   2              for (j=0;j<8;j++)
 253   2              {
 254   3                  if (Reg_CRC & 0x0001)
 255   3                  {
 256   4                     Reg_CRC=Reg_CRC>>1^0XA001;
 257   4                  }
 258   3                  else
 259   3                  {
 260   4                     Reg_CRC>>=1;
 261   4                  }
 262   3              }
 263   2          }
 264   1        if(mode == 1)
 265   1        {
 266   2          *updata++ = (u8)Reg_CRC;
 267   2          *updata = (u8)(Reg_CRC>>8);
 268   2        }
 269   1        
 270   1        return Reg_CRC;
 271   1      }
