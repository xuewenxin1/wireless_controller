 314          /*****************************************************************************
 315           函 数 名  : UART5_TX_ISR_PC
 316           功能描述  : 串口5发送中断
 317          *****************************************************************************/
 318          void UART5_TX_ISR_PC(void) interrupt 12
 319          {
 320   1          EA = 0;
 321   1          SCON3T &= 0xFE;   // 清发送中断标志
 322   1      
 323   1          if (nUart5SendIndex > 0)
 324   1          {
 325   2      //        SBUF3_TX = *pUart5SendAddr++;
