                  BODE3_DIV_H = 0x2A;
                  BODE3_DIV_L = 0x00;
              #else
 145   1          BODE3_DIV_H = UART45_BAUD_DIV_H;
 146   1          BODE3_DIV_L = UART45_BAUD_DIV_L;
 147   1      #endif
