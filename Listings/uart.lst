 126          void UART2_ISR_PC(void)    interrupt 4
 127          {
 128   1          u8 res=0;
 129   1          EA=0;
 130   1          if(RI0==1)
 131   1          {
 132   2                      res = SBUF0;
 133   2                      uart_receive_input(res);
 134   2                      RI0=0;
 135   2          }
 136   1          
 137   1              if(TI0==1)
