  61          void UART2_Init(void)
  62          {
  63   1              MUX_SEL |= 0x40;
  64   1              P0MDOUT &= 0XCF;
  65   1              P0MDOUT |= 0X10;
  66   1              SCON0   = 0x50;
  67   1              ADCON   = 0x80;
  68   1              PCON   &= 0x7F;
  69   1              
  70   1              SREL0H  = WIFI_BAUDRATE_9600 >> 8;
  71   1              SREL0L  = WIFI_BAUDRATE_9600 & 0xFF;
  72   1              
  73   1              ES0     = 0;
  74   1          EA      = 1;
  75   1      }
  76          
  77          //发送一个字节
  78          void Uart2SendData(u8 byte)
  79          {
  80   1              ES0 = 0;
  81   1              SBUF0 = byte;
  82   1              while(!TI0);
  83   1              TI0 = 0;
  84   1              ES0 = 1;
  85   1      }
  86          
  87          
  88          void UART2_ISR_PC(void)    interrupt 4
  89          {
  90   1          u8 res;
  91   1              EA=0;
  92   1          if(RI0)
  93   1          {
  94   2                      RI0=0;
  95   2                      res = SBUF0;
  96   2                      uart_receive_input(res);
  97   2          }
  98   1          
  99   1              if(TI0==1)
 100   1          {
 101   2                      TI0=0;
 102   2                      
 103   2                      if (nUart0SendIndex > 0)
 104   2                      {
 105   3                              SBUF0 = *pUart0SendAddr;
 106   3                              pUart0SendAddr++;
 107   3                              nUart0SendIndex--;
 108   3                              nUart0Sending = 1;
 109   3                      }
 110   2                      else
 111   2                      {
 112   3                              nUart0Sending   = 0;
 113   3                      }
 114   2                      
 115   2                      uart2_busy=0;
 116   2          }
