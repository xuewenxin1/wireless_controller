 296          /*****************************************************************************
 297           函 数 名  : void UART5_Init(void)
 298           功能描述  : 串口5初始化（RS485）
 299           修改历史  :
 300            1.日    期   : 2019年4月30日
 301              作    者   : chengjing
 302              修改内容   : 创建
C51 COMPILER V9.59.0.0   UART                                                              06/18/2026 09:22:44 PAGE 6   

 303          *****************************************************************************/
 304          void UART5_Init(void)
 305          {
 306   1          SCON3T = 0x80;
 307   1          SCON3R = 0x80;
 308   1      
 309   1      #ifdef UART5BUAD2400
                  BODE3_DIV_H = 0x2A;
                  BODE3_DIV_L = 0x00;
              #else
 313   1          BODE3_DIV_H = 0x0A;   // 9600bps
 314   1          BODE3_DIV_L = 0x80;
 315   1      #endif
 316   1      
 317   1          ES3T = 1;     // 发送中断
 318   1          ES3R = 1;     // 接收中断
 319   1      
 320   1          RS485_TX_EN = 0;   // 默认接收
 321   1          EA = 1;
 322   1      }
 323          
 324          /*****************************************************************************
 325           函 数 名  : UART5_SendStr
 326           功能描述  : 串口5发送字符串（RS485）
 327           输入参数  : pstr   - 数据首地址
 328                       strlen - 数据长度
 329           修改历史  :
 330            1.日    期   : 2019年4月30日
 331              作    者   : chengjing
 332              修改内容   : 创建
 333          *****************************************************************************/
 334          void UART5_SendStr(u8 *pstr, u16 strlen)
 335          {
 336   1          if ((pstr == NULL) || (strlen < 8) )//|| (strlen > UART5_MAX_LEN)
 337   1              return;
 338   1      
 339   1          pUart5SendAddr  = pstr;
 340   1          nUart5SendIndex = strlen;
 341   1      
 342   1          RS485_TX_EN = 1;          // 切到发送
 343   1      //    ES3R = 0;                 // 发送期间禁止接收中断
 344   1      
 345   1          SBUF3_TX = *pUart5SendAddr;
 346   1              pUart5SendAddr++;
 347   1          nUart5SendIndex--;
 348   1          nUart5Sending = 1;
 349   1              ES3R = 0;
 350   1      }
