 258          /*****************************************************************************
 259           函 数 名  : void UART5_Init(void)
 260           功能描述  : 串口5初始化（RS485）
 261           修改历史  :
 262            1.日    期   : 2019年4月30日
 263              作    者   : chengjing
 264              修改内容   : 创建
 265          *****************************************************************************/
 266          void UART5_Init(void)
 267          {
 268   1          SCON3T = 0x80;
 269   1          SCON3R = 0x80;
 270   1      
 271   1      #ifdef UART5BUAD2400
                  BODE3_DIV_H = 0x2A;
                  BODE3_DIV_L = 0x00;
              #else
 275   1          BODE3_DIV_H = 0x0A;   // 9600bps
 276   1          BODE3_DIV_L = 0x80;
 277   1      #endif
 278   1      
 279   1          ES3T = 1;     // 发送中断
 280   1          ES3R = 1;     // 接收中断
 281   1      
 282   1          RS485_TX_EN = 0;   // 默认接收
 283   1          EA = 1;
 284   1      }
 285          
 286          /*****************************************************************************
 287           函 数 名  : UART5_SendStr
 288           功能描述  : 串口5发送字符串（RS485）
 289           输入参数  : pstr   - 数据首地址
 290                       strlen - 数据长度
 291           修改历史  :
 292            1.日    期   : 2019年4月30日
 293              作    者   : chengjing
 294              修改内容   : 创建
 295          *****************************************************************************/
 296          void UART5_SendStr(u8 *pstr, u16 strlen)
 297          {
 298   1          if ((pstr == NULL) || (strlen < 8) )//|| (strlen > UART5_MAX_LEN)
 299   1              return;
 300   1      
 301   1          pUart5SendAddr  = pstr;
 302   1          nUart5SendIndex = strlen;
C51 COMPILER V9.59.0.0   UART                                                              06/18/2026 10:05:38 PAGE 6   

 303   1      
 304   1          RS485_TX_EN = 1;          // 切到发送
 305   1      //    ES3R = 0;                 // 发送期间禁止接收中断
 306   1      
 307   1          SBUF3_TX = *pUart5SendAddr;
 308   1              pUart5SendAddr++;
 309   1          nUart5SendIndex--;
 310   1          nUart5Sending = 1;
 311   1              ES3R = 0;
 312   1      }
