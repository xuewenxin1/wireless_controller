 156          /*****************************************************************************
 157           函 数 名  : UART5_SendStr
 158           功能描述  : 串口5发送字符串（RS485）
 159           输入参数  : pstr   - 数据首地址
 160                       strlen - 数据长度
 161           修改历史  :
 162            1.日    期   : 2019年4月30日
 163              作    者   : chengjing
 164              修改内容   : 创建
 165          *****************************************************************************/
 166          void UART5_SendStr(u8 *pstr, u16 strlen)
 167          {
 168   1          if ((pstr == NULL) || (strlen < 8) )//|| (strlen > UART5_MAX_LEN)
 169   1              return;
 170   1      
 171   1          uart5_rx_count = 0;
 172   1          pUart5SendAddr  = pstr;
 173   1          nUart5SendIndex = strlen;
 174   1      
 175   1          RS485_TX_EN = 1;          // 切到发送
 176   1      
 177   1          SBUF3_TX = *pUart5SendAddr;
 178   1              pUart5SendAddr++;
C51 COMPILER V9.59.0.0   UART                                                              07/10/2026 16:24:34 PAGE 4   

 179   1          nUart5SendIndex--;
 180   1          nUart5Sending = 1;
 181   1              ES3R = 0;
 182   1      }
