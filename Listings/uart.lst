 354           功能描述  : 串口5发送中断
 355          *****************************************************************************/
 356          void UART5_TX_ISR_PC(void) interrupt 12
 357          {
 358   1          EA = 0;
 359   1          SCON3T &= 0xFE;   // 清发送中断标志
 360   1      
 361   1          if (nUart5SendIndex > 0)
 362   1          {
 363   2      //        SBUF3_TX = *pUart5SendAddr++;
 364   2                      SBUF3_TX = *pUart5SendAddr;
C51 COMPILER V9.59.0.0   UART                                                              06/18/2026 09:22:44 PAGE 7   

 365   2                      pUart5SendAddr++;
 366   2              nUart5SendIndex--;
 367   2          }
 368   1          else
 369   1          {
 370   2                      ES3R = 1;             // 允许接收中断
 371   2              nUart5Sending = 0;
 372   2              RS485_TX_EN = 0;      // 切回接收
 373   2              
 374   2          }
 375   1      
 376   1          EA = 1;
 377   1      }
