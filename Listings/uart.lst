  63          void UART2_Init(void)
  64          {
  65   1              MUX_SEL |= 0x40;
  66   1              P0MDOUT &= 0XCF;
  67   1              P0MDOUT |= 0X10;
  68   1              SCON0   = 0x50;
  69   1              ADCON   = 0x80;
  70   1              PCON   &= 0x7F;
  71   1              
  72   1              SREL0H  = WIFI_BAUDRATE_9600 >> 8;
  73   1              SREL0L  = WIFI_BAUDRATE_9600 & 0xFF;
  74   1              
  75   1              ES0     = 1;
  76   1          EA      = 1;
  77   1      }
  78          
  79          //发送一个字节（保持 ES0 开启，避免上报应答期间丢失 WiFi 下发帧）
  80          void Uart2SendData(u8 byte)
  81          {
  82   1              uart2_busy = 1;
  83   1              TI0 = 0;
  84   1              SBUF0 = byte;
  85   1              while(!TI0) {
  86   2                      WDT_RST();
  87   2                      wifi_uart_rx_pull();
  88   2              }
  89   1              TI0 = 0;
  90   1              uart2_busy = 0;
  91   1      }
  92          
  93          
  94          void UART2_ISR_PC(void)    interrupt 4
  95          {
  96   1          u8 res;
  97   1              EA = 0;
  98   1      
  99   1          if(RI0)
 100   1          {
 101   2                      RI0=0;
 102   2                      res = SBUF0;
 103   2                      wifi_rx_byte_total++;
 104   2                      uart_receive_input(res);
 105   2          }
 106   1          
 107   1              if(TI0==1)
 108   1          {
 109   2                      if(!uart2_busy)
 110   2                      {
 111   3                              TI0=0;
 112   3                              if (nUart0SendIndex > 0)
 113   3                              {
 114   4                                      SBUF0 = *pUart0SendAddr;
 115   4                                      pUart0SendAddr++;
 116   4                                      nUart0SendIndex--;
C51 COMPILER V9.59.0.0   UART                                                              07/10/2026 16:24:34 PAGE 3   

 117   4                                      nUart0Sending = 1;
 118   4                              }
 119   3                              else
 120   3                              {
 121   4                                      nUart0Sending   = 0;
 122   4                              }
 123   3                      }
 124   2          }
 125   1          EA = 1;
 126   1      }
