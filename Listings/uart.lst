 211          /*****************************************************************************
 212           函 数 名  : UART5_RX_ISR_PC
 213           功能描述  : 串口5接收中断（Modbus）
 214          *****************************************************************************/
 215          void UART5_RX_ISR_PC(void) interrupt 13
 216          {
 217   1          u8 res;
 218   1          u16 modbus_len = 0;
 219   1      
 220   1          EA = 0;
 221   1      
 222   1          if ((SCON3R & 0x01) == 0x01)
 223   1          {
 224   2              res = SBUF3_RX;
 225   2              SCON3R &= 0xFE;
 226   2      
 227   2              if (uart5_rx_count >= UART5_MAX_LEN)
 228   2                  uart5_rx_count = 0;
 229   2      
 230   2              if (uart5_rx_count == 0 && res != 0x01)
 231   2                  ;
 232   2              else
 233   2              {
 234   3                  Uart5_Rx[uart5_rx_count++] = res;
 235   3      
 236   3                  if (uart5_rx_count >= 3)
 237   3                  {
 238   4                      if (Uart5_Rx[0] != 0x01)
 239   4                          uart5_rx_count = 0;
 240   4                      else if (Uart5_Rx[1] == 0x03)
C51 COMPILER V9.59.0.0   UART                                                              07/10/2026 16:24:34 PAGE 5   

 241   4                          modbus_len = (u16)Uart5_Rx[2] + 5;
 242   4                      else if (Uart5_Rx[1] == 0x06 || Uart5_Rx[1] == 0x10)
 243   4                          modbus_len = 8;
 244   4                      else
 245   4                          modbus_len = 8;
 246   4      
 247   4                      if (modbus_len < 8)
 248   4                          modbus_len = 8;
 249   4                      if (modbus_len > UART5_MAX_LEN)
 250   4                          uart5_rx_count = 0;
 251   4                      else if (uart5_rx_count >= modbus_len)
 252   4                      {
 253   5                          modbus_res_finish = 1;
 254   5                          modbus_error = 0;
 255   5                          uart5_rx_count = 0;
 256   5                          Send_Count = 0;
 257   5                      }
 258   4                  }
 259   3              }
 260   2          }
 261   1          EA = 1;
 262   1      }
 263          /*****************************************************************************
 264           函 数 名  : void UART4_Init(void)
 265           功能描述  : 串口4初始化 (用于调试 printf)
 266           波 特 率  : 9600 @ 206.4384MHz
 267          *****************************************************************************/
 268          void UART4_Init(void)
 269          {
 270   1          SCON2T = 0x80;
 271   1          SCON2R = 0x80;
 272   1          
 273   1          BODE2_DIV_H = UART45_BAUD_DIV_H;
 274   1          BODE2_DIV_L = UART45_BAUD_DIV_L;
 275   1          
 276   1          // 初始化 P0.0 为推挽输出 (TR4 方向控制)
 277   1          P0MDOUT |= 0x01;        
 278   1          RS485_UART4_EN = 0;
 279   1      }
 280          
 281          /*****************************************************************************
 282           函 数 名  : char putchar(char c)
 283           功能描述  : 重定向 putchar 到 UART4，支持 printf 输出
 284           注意事项  : RS485 半双工模式，发送前后需切换方向引脚
 285          *****************************************************************************/
 286          char putchar(char c)
 287          {
 288   1          u16 i;
 289   1          RS485_UART4_EN = 1;      // 切换到发送模式
 290   1          
 291   1          SBUF2_TX = c;
 292   1          while(!(SCON2T & 0x01)); // 等待发送完成标志 (TI2)
 293   1          SCON2T &= 0xFE;          // 清除 TI2 标志
 294   1          
 295   1          // 9600波特率下，TI置位可能略早于停止位发送完毕
 296   1          // 增加约 100us 延时（对应 1 个位的时间）以确保 485 切换不会截断停止位
 297   1          for(i=0; i<100; i++);
 298   1          
 299   1          RS485_UART4_EN = 0;      // 切换回接收模式
 300   1          
 301   1          WDT_RST();               // 每次打印字符后喂狗，防止长字符串导致复位
 302   1          return c;
