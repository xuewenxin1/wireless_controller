 327   2                      pUart5SendAddr++;
 328   2              nUart5SendIndex--;
 329   2          }
 330   1          else
 331   1          {
 332   2                      ES3R = 1;             // 允许接收中断
 333   2              nUart5Sending = 0;
 334   2              RS485_TX_EN = 0;      // 切回接收
 335   2              
 336   2          }
 337   1      
 338   1          EA = 1;
 339   1      }
