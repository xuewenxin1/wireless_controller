 434          /*****************************************************************************
 435           函 数 名  : void UART4_Init(void)
 436           功能描述  : 串口4初始化 (用于调试 printf)
 437           波 特 率  : 9600 @ 206.4384MHz
 438          *****************************************************************************/
 439          void UART4_Init(void)
 440          {
 441   1          SCON2T = 0x80;
 442   1          SCON2R = 0x80;
 443   1          
 444   1          // 设置波特率为 9600
 445   1          // DIV = 206438400 / (8 * 9600) = 2688 (0x0A80)
 446   1          BODE2_DIV_H = 0x0A;     
 447   1          BODE2_DIV_L = 0x80;
 448   1          
 449   1          // 初始化 P0.0 为推挽输出 (TR4 方向控制)
 450   1          P0MDOUT |= 0x01;        
 451   1          RS485_UART4_EN = 0;
 452   1      }
 453          
 454          /*****************************************************************************
 455           函 数 名  : char putchar(char c)
 456           功能描述  : 重定向 putchar 到 UART4，支持 printf 输出
 457           注意事项  : RS485 半双工模式，发送前后需切换方向引脚
 458          *****************************************************************************/
 459          char putchar(char c)
 460          {
 461   1          u16 i;
 462   1          RS485_UART4_EN = 1;      // 切换到发送模式
 463   1          
 464   1          SBUF2_TX = c;
 465   1          while(!(SCON2T & 0x01)); // 等待发送完成标志 (TI2)
 466   1          SCON2T &= 0xFE;          // 清除 TI2 标志
 467   1          
 468   1          // 9600波特率下，TI置位可能略早于停止位发送完毕
 469   1          // 增加约 100us 延时（对应 1 个位的时间）以确保 485 切换不会截断停止位
 470   1          for(i=0; i<100; i++);
 471   1          
 472   1          RS485_UART4_EN = 0;      // 切换回接收模式
 473   1          
 474   1          WDT_RST();               // 每次打印字符后喂狗，防止长字符串导致复位
 475   1          return c;
 476   1      }


