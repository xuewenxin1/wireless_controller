 184          /*****************************************************************************
 185           函 数 名  : UART5_TX_ISR_PC
 186           功能描述  : 串口5发送中断
 187          *****************************************************************************/
 188          void UART5_TX_ISR_PC(void) interrupt 12
 189          {
 190   1          EA = 0;
 191   1          SCON3T &= 0xFE;   // 清发送中断标志
 192   1      
 193   1          if (nUart5SendIndex > 0)
 194   1          {
 195   2                      SBUF3_TX = *pUart5SendAddr;
 196   2                      pUart5SendAddr++;
 197   2              nUart5SendIndex--;
 198   2          }
 199   1          else
 200   1          {
 201   2              u16 i;
 202   2      
 203   2              nUart5Sending = 0;
 204   2              RS485_TX_EN = 0;      // 切回接收
 205   2              for(i = 0; i < 120; i++);  // ~1 字符时间 @9600，避免过早开 RX 丢首字节
 206   2              ES3R = 1;
 207   2          }
 208   1          EA = 1;
 209   1      }
