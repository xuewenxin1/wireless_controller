 472          /*****************************************************************************
 473           函 数 名  : void UART4_Init(void)
 474           功能描述  : 串口4初始化 (用于调试 printf)
 475           波 特 率  : 9600 @ 206.4384MHz
 476          *****************************************************************************/
 477          void UART4_Init(void)
 478          {
 479   1          SCON2T = 0x80;
 480   1          SCON2R = 0x80;
 481   1          
 482   1          // 设置波特率为 9600
 483   1          // DIV = 206438400 / (8 * 9600) = 2688 (0x0A80)
 484   1          BODE2_DIV_H = 0x0A;     
 485   1          BODE2_DIV_L = 0x80;
 486   1          
 487   1          // 初始化 P0.0 为推挽输出 (TR4 方向控制)
 488   1          P0MDOUT |= 0x01;        
C51 COMPILER V9.59.0.0   UART                                                              06/18/2026 09:22:44 PAGE 9   

 489   1          RS485_UART4_EN = 0;
 490   1      }
 491          
 492          /*****************************************************************************
 493           函 数 名  : char putchar(char c)
 494           功能描述  : 重定向 putchar 到 UART4，支持 printf 输出
 495           注意事项  : RS485 半双工模式，发送前后需切换方向引脚
 496          *****************************************************************************/
 497          char putchar(char c)
 498          {
 499   1          u16 i;
 500   1          RS485_UART4_EN = 1;      // 切换到发送模式
 501   1          
 502   1          SBUF2_TX = c;
 503   1          while(!(SCON2T & 0x01)); // 等待发送完成标志 (TI2)
 504   1          SCON2T &= 0xFE;          // 清除 TI2 标志
 505   1          
 506   1          // 9600波特率下，TI置位可能略早于停止位发送完毕
 507   1          // 增加约 100us 延时（对应 1 个位的时间）以确保 485 切换不会截断停止位
 508   1          for(i=0; i<100; i++);
 509   1          
 510   1          RS485_UART4_EN = 0;      // 切换回接收模式
 511   1          
 512   1          WDT_RST();               // 每次打印字符后喂狗，防止长字符串导致复位
 513   1          return c;
 514   1      }
