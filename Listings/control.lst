 227   1              Temp_Limit((unsigned short)vp, unit ? 'F' : 'C');
 228   1              read_dgus_vp(vp, (u8 *)&temp, 1);
 229   1              if(unit)
 230   1                      SyncSetTempCachesFromC((u16)TempUnitTrans((signed short)temp, 'C'));
 231   1              else
 232   1                      SyncSetTempCachesFromC(temp);
 233   1              Modbus_Write_Ueser = TRUE;
 234   1              Ready_To_Save_Report();
 235   1              upload_dp_temp_set();
