1448          signed short TempUnitTrans(signed short temp, unsigned char type)
1449          {
1450   1              signed short Cache;
1451   1      
1452   1              if (type == 'C') // C=(F-32)*5/9
1453   1              {
1454   2                      if (temp < -22) //-623
1455   2                              temp = -22;
1456   2                      else if (temp > 266) // 687
1457   2                              temp = 266;
1458   2                      Cache = (temp - 32) * 10 * 5 / 9;
1459   2              }
1460   1              else if (type == 'F') // F=C*9/5+32
1461   1              {
1462   2                      if (temp < -30) //-364
1463   2                              temp = -30;
1464   2                      else if (temp > 130) // 364
1465   2                              temp = 130;
1466   2                      Cache = temp * 10 * 9 / 5 + 320;
1467   2              }
1468   1      
1469   1              Cache = (Cache > 0) ? ((Cache + 5) / 10) : ((Cache - 5) / 10);
1470   1              return Cache;
1471   1      }
