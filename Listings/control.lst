 195          static void Defrost_CheckExit(void)
 196          {
 197   1              u16 defrost_en;
 198   1              u16 duration_min;
 199   1              float evap_c;
 200   1              float t3_c;
 201   1      
 202   1              if(!Defrosting)
 203   1                      return;
 204   1      
 205   1              read_dgus_vp((u32)(0x201b), (u8 *)&defrost_en, 1);
 206   1              if(!defrost_en)
 207   1              {
 208   2                      if(Defrosting)
 209   2                              Modbus_SetDefrostDisplay(0);
 210   2                      return;
 211   2              }
 212   1      
 213   1              read_dgus_vp((u32)(0x3670), (u8 *)&duration_min, 1);
 214   1              if(!duration_min)
 215   1                      read_dgus_vp((u32)(0x1012), (u8 *)&duration_min, 1);
 216   1              if(duration_min > 0 && s_defrost_start_sec > 0)
 217   1              {
 218   2                      if(RTC_GetUnixLocal() - s_defrost_start_sec >= (u32)duration_min * 60UL)
 219   2                              goto defrost_exit;
 220   2              }
 221   1      
 222   1              read_dgus_vp((u32)(0x1006), (u8 *)&evap_c, 2);
 223   1              read_dgus_vp((u32)(0x1014), (u8 *)&t3_c, 2);
 224   1              if(s_defrost_start_sec > 0 && RTC_GetUnixLocal() - s_defrost_start_sec < 60UL)
 225   1                      return;
 226   1              if(evap_c > t3_c)
 227   1                      goto defrost_exit;
 228   1              return;
 229   1      
 230   1      defrost_exit:
 231   1              {
 232   2                      Modbus_SetDefrostDisplay(0);
 233   2                      s_defrost_start_sec = 0;
 234   2                      Modbus_Write_Ueser = TRUE;
 235   2                      upload_dp_defrost();
 236   2              }
 237   1      }
