 514          static u8 Timer_IsWeekdayMatch(u8 rtc_week)
 515          {
 516   1              u8 bit_idx, week_en;
 517   1              u16 week_mask = 0;
 518   1              u8 i;
 519   1      
 520   1              bit_idx = (rtc_week == 0) ? 6 : (u8)(rtc_week - 1);
 521   1              for(i = 0; i < 7; i++)
 522   1              {
 523   2                      read_dgus_vp((u32)(0x4510 + i), (u8 *)&week_en, 1);
 524   2                      if(week_en)
 525   2                              week_mask |= (u16)(1 << i);
 526   2              }
 527   1              if(week_mask == 0)
 528   1                      return 1;
 529   1              return (week_mask & (u16)(1 << bit_idx)) ? 1 : 0;
 530   1      }
