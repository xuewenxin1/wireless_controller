 148   1              {
 149   2                      read_dgus_vp((u32)(0x4010 + i),(u8 *)&HomePage_Power,1);
 150   2                      if(HomePage_Power == 1)
 151   2                      {
 152   3                              first_one = i;
 153   3                              break;
 154   3                      }
 155   2              }
 156   1              HomePage_Power = 0;
 157   1              if(first_one < 6)
 158   1              {
 159   2                      read_dgus_vp((u32)(0x1101 + (u16)first_one * 0x20),(u8 *)&HomePage_Power,1);
 160   2                      if(HomePage_Power > 4)
 161   2                      {
 162   3                              read_dgus_vp((u32)(0x4700 + first_one),(u8 *)&HomePage_Power,1);
 163   3                              if(HomePage_Power > 4)
 164   3                                      HomePage_Power = 0;
 165   3                      }
 166   2              }
 167   1              write_dgus_vp((u32)(0x2001),(u8 *)&HomePage_Power,1);
 168   1              if(HomePage_Power != s_last_anim_mode)
 169   1              {
 170   2                      HomePage_UpdateModeAnimation((u8)HomePage_Power);
 171   2                      s_last_anim_mode = (u8)HomePage_Power;
