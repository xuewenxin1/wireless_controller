 121          void SyncLink_ApplySwitch(unsigned char pwr, unsigned char src)
 122          {
 123   1              u16 mode;
 124   1              u16 old_vp;
 125   1              u16 new_vp;
 126   1              u16 pwr16;
 127   1      
 128   1              if(pwr > 1)
 129   1                      pwr = 1;
 130   1              pwr16 = pwr;
 131   1      
 132   1              old_vp = Control_GetExtPowerLastCmd();
 133   1              if(old_vp == 0xFFFF)
 134   1              {
 135   2                      read_dgus_vp((u32)0x4021, (u8 *)&old_vp, 1);
 136   2                      if(old_vp > 1)
 137   2                              old_vp = 1;
 138   2              }
 139   1              else if(old_vp > 1)
 140   1                      old_vp = 1;
 141   1      
 142   1              if(old_vp == pwr16)
 143   1                      return;
 144   1      
 145   1              read_dgus_vp((u32)0x2002, (u8 *)&mode, 1);
 146   1              if(pwr16 == 0)
 147   1                      mode = 0;
 148   1              else if(mode == 0)
 149   1                      mode = 1;
 150   1              write_dgus_vp((u32)0x2002, (u8 *)&mode, 1);
 151   1              if(src == SYNC_SRC_APP)
 152   1                      write_dgus_vp((u32)0x4021, (u8 *)&pwr16, 1);
 153   1      
 154   1              read_dgus_vp((u32)0x4021, (u8 *)&new_vp, 1);
 155   1              if(new_vp > 1)
 156   1                      new_vp = 1;
 157   1      
 158   1              printf("[SYNC] %c pwr=%u vp4021=%u mode2002=%u\r\n",
 159   1                      (char)src, (u16)pwr16, (u16)new_vp, (u16)mode);
 160   1      
 161   1              Control_AckExtPowerVp(pwr16);
 162   1              App_ControlBlockExtInput(src == SYNC_SRC_SCR ? 15 : 8);
 163   1      
 164   1              g_mb_switch_wr_src = (u8)src;
 165   1              Modbus_TriggerUserWriteWith(pwr16, mode);
 166   1      }
