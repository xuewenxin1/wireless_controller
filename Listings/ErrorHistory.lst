 389          
 390          static unsigned char ErrorHistory_IsValidCode(unsigned char fault_code)
 391          {
 392   1              return (fault_code >= 1 && fault_code <= 64) ? 1 : 0;
 393   1      }
 394          
 395          static unsigned char ErrorHistory_ClampByte(u16 v, u8 maxv)
 396          {
 397   1              if(v > maxv)
 398   1                      return maxv;
 399   1              return (u8)v;
 400   1      }
 401          
 402          /* 记录格式: [0]月 [1]日 [2]时 [3]分 [4]故障码 */
 403          static void ErrorHistory_ReadTime(u8 *rec)
 404          {
 405   1              u16 year = 0;
 406   1              u16 month_vp = 0;
 407   1              u16 day = 0;
 408   1              u16 hour = 0;
 409   1              u16 minute = 0;
 410   1      
 411   1              read_dgus_vp((u32)0x3010, (u8 *)&year, 1);
 412   1              read_dgus_vp((u32)0x3011, (u8 *)&month_vp, 1);
 413   1              read_dgus_vp((u32)0x3012, (u8 *)&day, 1);
 414   1              read_dgus_vp((u32)0x3013, (u8 *)&hour, 1);
 415   1              read_dgus_vp((u32)0x3014, (u8 *)&minute, 1);
 416   1              rec[0] = (u8)RTC_MonthFromDisplayVp(year, month_vp);
 417   1              rec[1] = ErrorHistory_ClampByte(day, 31);
 418   1              rec[2] = ErrorHistory_ClampByte(hour, 23);
 419   1              rec[3] = ErrorHistory_ClampByte(minute, 59);
 420   1      }
 421          
 422          static void ErrorHistory_PackRec(u8 *out, u8 *rec)
 423          {
 424   1              u32 v;
 425   1      
C51 COMPILER V9.59.0.0   ERRORHISTORY                                                      06/18/2026 09:22:44 PAGE 8   

 426   1              if(!ErrorHistory_IsValidCode(rec[4]))
 427   1              {
 428   2                      out[0] = 0;
 429   2                      out[1] = 0;
 430   2                      out[2] = 0;
 431   2                      out[3] = 0;
 432   2                      return;
 433   2              }
 434   1              v = (u32)(rec[4] & 0x3F);
 435   1              v |= ((u32)(ErrorHistory_ClampByte(rec[3], 59) & 0x3F) << 6);
 436   1              v |= ((u32)(ErrorHistory_ClampByte(rec[2], 23) & 0x1F) << 12);
 437   1              v |= ((u32)(ErrorHistory_ClampByte(rec[1], 31) & 0x1F) << 17);
 438   1              v |= ((u32)(ErrorHistory_ClampByte(rec[0], 12) & 0x0F) << 22);
 439   1              out[0] = (u8)v;
 440   1              out[1] = (u8)(v >> 8);
 441   1              out[2] = (u8)(v >> 16);
 442   1              out[3] = (u8)(v >> 24);
 443   1      }
 444          
 445          static void ErrorHistory_UnpackRec(u8 *rec, u8 *in)
 446          {
 447   1              u32 v;
 448   1      
 449   1              v = (u32)in[0] | ((u32)in[1] << 8) | ((u32)in[2] << 16) | ((u32)in[3] << 24);
 450   1              if((v & 0x3F) == 0)
 451   1              {
 452   2                      rec[0] = 0;
 453   2                      rec[1] = 0;
 454   2                      rec[2] = 0;
 455   2                      rec[3] = 0;
 456   2                      rec[4] = 0;
 457   2                      return;
 458   2              }
 459   1              rec[4] = (u8)(v & 0x3F);
 460   1              rec[3] = (u8)((v >> 6) & 0x3F);
 461   1              rec[2] = (u8)((v >> 12) & 0x1F);
 462   1              rec[1] = (u8)((v >> 17) & 0x1F);
 463   1              rec[0] = (u8)((v >> 22) & 0x0F);
 464   1      }
 465          
 466          static void ErrorHistory_UnpackRecLegacy(u8 *rec, u8 *in)
 467          {
 468   1              u32 v;
 469   1              u8 month;
 470   1              u8 day;
 471   1              u8 hour;
 472   1      
 473   1              v = (u32)in[0] | ((u32)in[1] << 8) | ((u32)in[2] << 16) | ((u32)in[3] << 24);
 474   1              if((v & 0x3F) == 0)
 475   1              {
 476   2                      rec[0] = 0;
 477   2                      rec[1] = 0;
 478   2                      rec[2] = 0;
 479   2                      rec[3] = 0;
 480   2                      rec[4] = 0;
 481   2                      return;
 482   2              }
 483   1              hour = (u8)((v >> 6) & 0x1F);
 484   1              day = (u8)((v >> 11) & 0x1F);
 485   1              month = (u8)((v >> 16) & 0x0F);
 486   1              rec[0] = month;
 487   1              rec[1] = day;
C51 COMPILER V9.59.0.0   ERRORHISTORY                                                      06/18/2026 09:22:44 PAGE 9   

 488   1              rec[2] = hour;
 489   1              rec[3] = 0;
 490   1              rec[4] = (u8)(v & 0x3F);
 491   1      }
 492          
 493          static void ErrorHistory_ConvertLegacyRawRec(u8 *rec)
 494          {
 495   1              u8 month;
 496   1              u8 day;
 497   1              u8 hour;
 498   1              u8 fault_code;
 499   1      
 500   1              if(!ErrorHistory_IsValidCode(rec[4]))
 501   1              {
 502   2                      rec[0] = 0;
 503   2                      rec[1] = 0;
 504   2                      rec[2] = 0;
 505   2                      rec[3] = 0;
 506   2                      rec[4] = 0;
 507   2                      return;
 508   2              }
 509   1              month = rec[1];
 510   1              day = rec[2];
 511   1              hour = rec[3];
 512   1              fault_code = rec[4];
 513   1              rec[0] = month;
 514   1              rec[1] = day;
 515   1              rec[2] = hour;
 516   1              rec[3] = 0;
 517   1              rec[4] = fault_code;
 518   1      }
 519          
 520          void ErrorHistory_FlashWrite(u32 flash_vp_addr)
 521          {
 522   1              u8 packed[ERRORHISTORYNUM * 4];
 523   1              u8 i;
 524   1              u16 magic = ERRORHISTORY_FLASH_MAGIC;
 525   1      
 526   1              for(i = 0; i < ERRORHISTORYNUM; i++)
 527   1                      ErrorHistory_PackRec(packed + i * 4, ErrorHistory[i]);
 528   1              write_dgus_vp(flash_vp_addr, (u8 *)&magic, 1);
 529   1              write_dgus_vp(flash_vp_addr + 1, packed, (u16)(ERRORHISTORY_FLASH_WORDS - 1));
 530   1      }
 531          
 532          static u32 ErrorHistory_FlashVpAddr(void)
 533          {
 534   1              return (u32)(NOR_FLASH_FIRST + MEMORY_HEADER_WORDS + MEMORY_LANGUAGE_WORDS
 535   1                      + MEMORY_TIMER_SLOT_WORDS + MEMORY_INDOOR_TIMER_WORDS + 1 + 1);
 536   1      }
 537          
 538          void ErrorHistory_FlashCommitNow(void)
 539          {
 540   1              u16 enable_memory = 0;
 541   1      
 542   1              ErrorHistory_FlashWrite(ErrorHistory_FlashVpAddr());
 543   1              read_dgus_vp((u32)(0x3508), (u8 *)&enable_memory, 1);
 544   1              if(enable_memory == 1)
 545   1              {
 546   2                      Write_Memory();
 547   2                      Write_Nor_Flash();
 548   2                      Save_Flash_Flag = 0;
 549   2                      Flash_Save_Count = 0;
C51 COMPILER V9.59.0.0   ERRORHISTORY                                                      06/18/2026 09:22:44 PAGE 10  

 550   2              }
 551   1      }
