 390          
 391          static unsigned char ErrorHistory_IsValidCode(unsigned char fault_code)
 392          {
 393   1              return (fault_code >= 1 && fault_code <= 64) ? 1 : 0;
 394   1      }
 395          
 396          static unsigned char ErrorHistory_ClampByte(u16 v, u8 maxv)
 397          {
 398   1              if(v > maxv)
 399   1                      return maxv;
 400   1              return (u8)v;
 401   1      }
 402          
 403          /* 记录格式: [0]月 [1]日 [2]时 [3]分 [4]故障码 */
 404          static void ErrorHistory_ReadTime(u8 *rec)
 405          {
 406   1              u16 year = 0;
 407   1              u16 month_vp = 0;
 408   1              u16 day = 0;
 409   1              u16 hour = 0;
 410   1              u16 minute = 0;
 411   1      
 412   1              read_dgus_vp((u32)0x3010, (u8 *)&year, 1);
 413   1              read_dgus_vp((u32)0x3011, (u8 *)&month_vp, 1);
 414   1              read_dgus_vp((u32)0x3012, (u8 *)&day, 1);
 415   1              read_dgus_vp((u32)0x3013, (u8 *)&hour, 1);
 416   1              read_dgus_vp((u32)0x3014, (u8 *)&minute, 1);
 417   1              rec[0] = (u8)RTC_MonthFromDisplayVp(year, month_vp);
 418   1              rec[1] = ErrorHistory_ClampByte(day, 31);
 419   1              rec[2] = ErrorHistory_ClampByte(hour, 23);
 420   1              rec[3] = ErrorHistory_ClampByte(minute, 59);
 421   1      }
 422          
 423          static void ErrorHistory_PackRec(u8 *out, u8 *rec)
 424          {
 425   1              u32 v;
C51 COMPILER V9.59.0.0   ERRORHISTORY                                                      07/09/2026 13:23:52 PAGE 8   

 426   1      
 427   1              if(!ErrorHistory_IsValidCode(rec[4]))
 428   1              {
 429   2                      out[0] = 0;
 430   2                      out[1] = 0;
 431   2                      out[2] = 0;
 432   2                      out[3] = 0;
 433   2                      return;
 434   2              }
 435   1              v = (u32)(rec[4] & 0x3F);
 436   1              v |= ((u32)(ErrorHistory_ClampByte(rec[3], 59) & 0x3F) << 6);
 437   1              v |= ((u32)(ErrorHistory_ClampByte(rec[2], 23) & 0x1F) << 12);
 438   1              v |= ((u32)(ErrorHistory_ClampByte(rec[1], 31) & 0x1F) << 17);
 439   1              v |= ((u32)(ErrorHistory_ClampByte(rec[0], 12) & 0x0F) << 22);
 440   1              out[0] = (u8)v;
 441   1              out[1] = (u8)(v >> 8);
 442   1              out[2] = (u8)(v >> 16);
 443   1              out[3] = (u8)(v >> 24);
 444   1      }
 445          
 446          static void ErrorHistory_UnpackRec(u8 *rec, u8 *in)
 447          {
 448   1              u32 v;
 449   1      
 450   1              v = (u32)in[0] | ((u32)in[1] << 8) | ((u32)in[2] << 16) | ((u32)in[3] << 24);
 451   1              if((v & 0x3F) == 0)
 452   1              {
 453   2                      rec[0] = 0;
 454   2                      rec[1] = 0;
 455   2                      rec[2] = 0;
 456   2                      rec[3] = 0;
 457   2                      rec[4] = 0;
 458   2                      return;
 459   2              }
 460   1              rec[4] = (u8)(v & 0x3F);
 461   1              rec[3] = (u8)((v >> 6) & 0x3F);
 462   1              rec[2] = (u8)((v >> 12) & 0x1F);
 463   1              rec[1] = (u8)((v >> 17) & 0x1F);
 464   1              rec[0] = (u8)((v >> 22) & 0x0F);
 465   1      }
 466          
 467          static void ErrorHistory_UnpackRecLegacy(u8 *rec, u8 *in)
 468          {
 469   1              u32 v;
 470   1              u8 month;
 471   1              u8 day;
 472   1              u8 hour;
 473   1      
 474   1              v = (u32)in[0] | ((u32)in[1] << 8) | ((u32)in[2] << 16) | ((u32)in[3] << 24);
 475   1              if((v & 0x3F) == 0)
 476   1              {
 477   2                      rec[0] = 0;
 478   2                      rec[1] = 0;
 479   2                      rec[2] = 0;
 480   2                      rec[3] = 0;
 481   2                      rec[4] = 0;
 482   2                      return;
 483   2              }
 484   1              hour = (u8)((v >> 6) & 0x1F);
 485   1              day = (u8)((v >> 11) & 0x1F);
 486   1              month = (u8)((v >> 16) & 0x0F);
 487   1              rec[0] = month;
C51 COMPILER V9.59.0.0   ERRORHISTORY                                                      07/09/2026 13:23:52 PAGE 9   

 488   1              rec[1] = day;
 489   1              rec[2] = hour;
 490   1              rec[3] = 0;
 491   1              rec[4] = (u8)(v & 0x3F);
 492   1      }
 493          
 494          static void ErrorHistory_ConvertLegacyRawRec(u8 *rec)
 495          {
 496   1              u8 month;
 497   1              u8 day;
 498   1              u8 hour;
 499   1              u8 fault_code;
 500   1      
 501   1              if(!ErrorHistory_IsValidCode(rec[4]))
 502   1              {
 503   2                      rec[0] = 0;
 504   2                      rec[1] = 0;
 505   2                      rec[2] = 0;
 506   2                      rec[3] = 0;
 507   2                      rec[4] = 0;
 508   2                      return;
 509   2              }
 510   1              month = rec[1];
 511   1              day = rec[2];
 512   1              hour = rec[3];
 513   1              fault_code = rec[4];
 514   1              rec[0] = month;
 515   1              rec[1] = day;
 516   1              rec[2] = hour;
 517   1              rec[3] = 0;
 518   1              rec[4] = fault_code;
 519   1      }
 520          
 521          void ErrorHistory_FlashWrite(u32 flash_vp_addr)
 522          {
 523   1              u8 packed[ERRORHISTORYNUM * 4];
 524   1              u8 i;
 525   1              u16 magic = ERRORHISTORY_FLASH_MAGIC;
 526   1      
 527   1              for(i = 0; i < ERRORHISTORYNUM; i++)
 528   1                      ErrorHistory_PackRec(packed + i * 4, ErrorHistory[i]);
 529   1              write_dgus_vp(flash_vp_addr, (u8 *)&magic, 1);
 530   1              write_dgus_vp(flash_vp_addr + 1, packed, (u16)(ERRORHISTORY_FLASH_WORDS - 1));
 531   1      }
 532          
 533          static u32 ErrorHistory_FlashVpAddr(void)
 534          {
 535   1              return (u32)(NOR_FLASH_FIRST + MEMORY_HEADER_WORDS + MEMORY_LANGUAGE_WORDS
 536   1                      + MEMORY_TIMER_SLOT_WORDS + MEMORY_INDOOR_TIMER_WORDS + 1 + 1);
 537   1      }
 538          
 539          void ErrorHistory_FlashCommitNow(void)
 540          {
 541   1              u16 enable_memory = 0;
 542   1      
 543   1              ErrorHistory_FlashWrite(ErrorHistory_FlashVpAddr());
 544   1              read_dgus_vp((u32)(0x3508), (u8 *)&enable_memory, 1);
 545   1              if(enable_memory == 1)
 546   1              {
 547   2                      Write_Memory();
 548   2                      Write_Nor_Flash();
 549   2                      Save_Flash_Flag = 0;
C51 COMPILER V9.59.0.0   ERRORHISTORY                                                      07/09/2026 13:23:52 PAGE 10  

 550   2                      Flash_Save_Count = 0;
 551   2              }
 552   1      }
