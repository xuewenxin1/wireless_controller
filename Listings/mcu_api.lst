  31          /**
  32           * @brief  hexиҪ¬bcd
  33           * @param[in] {Value_H} й«ҳеӯ—иҠӮ
  34           * @param[in] {Value_L} дҪҺеӯ—иҠӮ
  35           * @return иҪ¬жҚўе®ҢжҲҗеҗҺж•°жҚ®
  36           */
  37          unsigned char hex_to_bcd(unsigned char Value_H,unsigned char Value_L)
  38          {
  39   1          unsigned char bcd_value;
  40   1          
  41   1          if((Value_H >= '0') && (Value_H <= '9'))
  42   1              Value_H -= '0';
  43   1          else if((Value_H >= 'A') && (Value_H <= 'F'))
  44   1              Value_H = Value_H - 'A' + 10;
  45   1          else if((Value_H >= 'a') && (Value_H <= 'f'))
  46   1              Value_H = Value_H - 'a' + 10;
  47   1           
  48   1          bcd_value = Value_H & 0x0f;
  49   1          
  50   1          bcd_value <<= 4;
  51   1          if((Value_L >= '0') && (Value_L <= '9'))
  52   1              Value_L -= '0';
  53   1          else if((Value_L >= 'A') && (Value_L <= 'F'))
C51 COMPILER V9.59.0.0   MCU_API                                                           07/08/2026 17:12:49 PAGE 2   

  54   1              Value_L = Value_L - 'a' + 10;
  55   1          else if((Value_L >= 'a') && (Value_L <= 'f'))
  56   1              Value_L = Value_L - 'a' + 10;
  57   1          
  58   1          bcd_value |= Value_L & 0x0f;
  59   1      
  60   1          return bcd_value;
  61   1      }
