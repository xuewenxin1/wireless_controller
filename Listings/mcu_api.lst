              void voice_mcu_fun_set(unsigned char play, unsigned char bt_play)
              {
                  unsigned short send_len = 0;
                  unsigned char str[50];
                  
                  //MCUУ«Йуй«ТџѓС╗ЁТћ»ТїЂРђЮТњГТћЙ/ТџѓтЂюРђЮ РђЮУЊЮуЅЎт╝ђтЁ│РђЮ
                  
